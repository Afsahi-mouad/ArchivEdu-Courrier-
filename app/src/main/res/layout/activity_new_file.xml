<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">
    <View android:id="@+id/btnBack" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    <TextView android:id="@+id/tvUrgencyNormal" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    <TextView android:id="@+id/tvUrgencyUrgent" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    <View android:id="@+id/btnSave" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    <com.google.android.material.chip.ChipGroup android:id="@+id/cgSectors" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    <View android:id="@+id/cvAttachment" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    <TextView android:id="@+id/tvAttachmentName" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    <EditText android:id="@+id/etOriginalSerial" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    <EditText android:id="@+id/etRecipientName" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    <EditText android:id="@+id/etSubject" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    <EditText android:id="@+id/etNotes" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
</LinearLayout>